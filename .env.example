# Copy to `.env` and fill in (never commit `.env`).
# Use External Database URL from Render when connecting from your PC.

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Optional: set to false only if your Postgres URL already includes ssl params and you hit SSL errors.
# DATABASE_SSL_REQUIRE=true

# Resend (https://resend.com) — signup verification + order emails.
# RESEND_API_KEY=re_xxxxxxxx
#
# Until you verify your own domain at https://resend.com/domains , Resend only allows
# sending *testing* mail to the email address tied to your Resend account. To reach any
# customer address, verify a domain and set FROM to that domain, e.g.:
# RESEND_FROM_EMAIL=noreply@your-verified-domain.com
#
# Optional (default is onboarding@resend.dev — Resend’s test sender):
# RESEND_FROM_EMAIL=onboarding@resend.dev
